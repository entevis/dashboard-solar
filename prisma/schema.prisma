generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──────────────────────────────────────
// Enums
// ──────────────────────────────────────

enum UserRole {
  MAESTRO
  OPERATIVO
  CLIENTE
  CLIENTE_PERFILADO
}

enum ContingencyType {
  PREVENTIVE
  CORRECTIVE
}

enum ContingencyStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

// ──────────────────────────────────────
// Models
// ──────────────────────────────────────

model Portfolio {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  active      Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  powerPlants PowerPlant[]
  users       User[]       @relation("AssignedPortfolio")

  @@map("portfolios")
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  rut       String   @unique
  altName   String?  @map("alt_name")
  active    Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  powerPlants PowerPlant[]
  invoices    Invoice[]
  users       User[]
  contacts    Contact[]

  @@map("customers")
}

model Contact {
  id         Int      @id @default(autoincrement())
  customerId Int      @map("customer_id")
  name       String
  rut        String?
  phone      String?
  role       String?
  email      String?
  active     Int      @default(1)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("contacts")
}

model Address {
  id         Int      @id @default(autoincrement())
  powerPlantId Int    @unique @map("power_plant_id")
  address    String?
  reference  String?
  city       String?
  county     String?
  country    String?  @default("Chile")
  postalCode String?  @map("postal_code")
  lat        Float?
  lng        Float?
  active     Int      @default(1)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  powerPlant PowerPlant @relation(fields: [powerPlantId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model PowerPlant {
  id                 Int       @id @default(autoincrement())
  name               String
  portfolioId        Int       @map("portfolio_id")
  customerId         Int       @map("customer_id")
  status             String    @default("active")
  city               String?
  location           String?
  capacityKw         Float     @map("capacity_kw")
  solcorId           String?   @map("solcor_id")
  distributorCompany String?   @map("distributor_company")
  tariffId           String?   @map("tariff_id")
  startDate          DateTime? @map("start_date")
  durationYears      Float?    @map("duration_years")
  specificYield      Float?    @map("specific_yield")
  active             Int       @default(1)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  portfolio         Portfolio              @relation(fields: [portfolioId], references: [id])
  customer          Customer               @relation(fields: [customerId], references: [id])
  address           Address?
  generationReports GenerationReport[]
  invoices          Invoice[]
  contingencies     Contingency[]
  userPermissions   UserPlantPermission[]

  @@index([portfolioId])
  @@index([customerId])
  @@map("power_plants")
}

model User {
  id                  Int      @id @default(autoincrement())
  supabaseId          String   @unique @map("supabase_id")
  email               String   @unique
  name                String
  role                UserRole
  customerId          Int?     @map("customer_id")
  assignedPortfolioId Int?     @map("assigned_portfolio_id")
  active              Int      @default(1)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  customer          Customer?             @relation(fields: [customerId], references: [id])
  assignedPortfolio Portfolio?            @relation("AssignedPortfolio", fields: [assignedPortfolioId], references: [id])
  plantPermissions  UserPlantPermission[]
  contingencies     Contingency[]         @relation("CreatedBy")
  auditLogs         AuditLog[]

  @@index([customerId])
  @@index([supabaseId])
  @@map("users")
}

model UserPlantPermission {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  powerPlantId Int      @map("power_plant_id")
  active       Int      @default(1)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  powerPlant PowerPlant @relation(fields: [powerPlantId], references: [id], onDelete: Cascade)

  @@unique([userId, powerPlantId])
  @@map("user_plant_permissions")
}

model GenerationReport {
  id           Int      @id @default(autoincrement())
  powerPlantId Int      @map("power_plant_id")
  periodMonth  Int      @map("period_month")
  periodYear   Int      @map("period_year")
  fileUrl      String   @map("file_url")
  fileName     String   @map("file_name")
  kwhGenerated Float    @map("kwh_generated")
  co2Avoided   Float    @map("co2_avoided")
  active       Int      @default(1)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  powerPlant PowerPlant @relation(fields: [powerPlantId], references: [id])

  @@unique([powerPlantId, periodMonth, periodYear])
  @@index([powerPlantId])
  @@map("generation_reports")
}

model Invoice {
  id           Int           @id @default(autoincrement())
  powerPlantId Int           @map("power_plant_id")
  customerId   Int           @map("customer_id")
  period       String
  amount       Float
  status       InvoiceStatus @default(PENDING)
  duemintId    String?       @map("duemint_id")
  charges      Json?
  pdfUrl       String?       @map("pdf_url")
  active       Int           @default(1)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  powerPlant PowerPlant @relation(fields: [powerPlantId], references: [id])
  customer   Customer   @relation(fields: [customerId], references: [id])

  @@index([powerPlantId])
  @@index([customerId])
  @@map("invoices")
}

model Contingency {
  id              Int               @id @default(autoincrement())
  powerPlantId    Int               @map("power_plant_id")
  type            ContingencyType
  description     String
  status          ContingencyStatus @default(OPEN)
  cost            Float?
  provider        String?
  workDescription String?           @map("work_description")
  createdById     Int               @map("created_by_id")
  closedAt        DateTime?         @map("closed_at")
  active          Int               @default(1)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  powerPlant PowerPlant @relation(fields: [powerPlantId], references: [id])
  createdBy  User       @relation("CreatedBy", fields: [createdById], references: [id])

  @@index([powerPlantId])
  @@index([status])
  @@map("contingencies")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  active     Int      @default(1)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}
