generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──────────────────────────────────────
// Enums
// ──────────────────────────────────────

enum UserRole {
  MAESTRO
  OPERATIVO
  CLIENTE
  CLIENTE_PERFILADO
}

enum ContingencyType {
  PREVENTIVE
  CORRECTIVE
}

enum ContingencyStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  SYNCED
}

// ──────────────────────────────────────
// Models
// ──────────────────────────────────────

model BankAccount {
  id            Int      @id @default(autoincrement())
  name          String
  bankName      String   @map("bank_name")
  accountType   String   @map("account_type")
  accountNumber String   @map("account_number")
  rut           String   @unique
  receiptEmail  String?  @map("receipt_email")
  active        Int      @default(1)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  portfolios Portfolio[]

  @@map("bank_accounts")
}

model Portfolio {
  id                Int      @id @default(autoincrement())
  name              String
  description       String?
  taxIdentification String?  @map("tax_identification")
  country           String?  @default("Chile")
  contact           String?
  bankAccountId     Int?     @map("bank_account_id")
  duemintCompanyId  String?  @map("duemint_company_id")
  active            Int      @default(1)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id])
  powerPlants PowerPlant[]
  users       User[]       @relation("AssignedPortfolio")
  invoices    Invoice[]

  @@map("portfolios")
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  rut       String   @unique
  altName   String?  @map("alt_name")
  active    Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  powerPlants PowerPlant[]
  invoices    Invoice[]
  users       User[]
  contacts    Contact[]

  @@map("customers")
}

model Contact {
  id         Int      @id @default(autoincrement())
  customerId Int      @map("customer_id")
  name       String
  rut        String?
  phone      String?
  role       String?
  email      String?
  active     Int      @default(1)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("contacts")
}

model Address {
  id         Int      @id @default(autoincrement())
  powerPlantId Int    @unique @map("power_plant_id")
  address    String?
  reference  String?
  city       String?
  county     String?
  country    String?  @default("Chile")
  postalCode String?  @map("postal_code")
  lat        Float?
  lng        Float?
  active     Int      @default(1)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  powerPlant PowerPlant @relation(fields: [powerPlantId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model PowerPlant {
  id                 Int       @id @default(autoincrement())
  name               String
  portfolioId        Int       @map("portfolio_id")
  customerId         Int       @map("customer_id")
  status             String    @default("active")
  city               String?
  location           String?
  capacityKw         Float     @map("capacity_kw")
  solcorId           String?   @map("solcor_id")
  distributorCompany String?   @map("distributor_company")
  tariffId           String?   @map("tariff_id")
  startDate          DateTime? @map("start_date")
  durationYears      Float?    @map("duration_years")
  specificYield      Float?    @map("specific_yield")
  panelCount         Int?      @map("panel_count")
  installationType   String?   @map("installation_type")
  surfaceM2          Float?    @map("surface_m2")
  economicSector     String?   @map("economic_sector")
  economicSector2    String?   @map("economic_sector_2")
  active             Int       @default(1)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  portfolio         Portfolio              @relation(fields: [portfolioId], references: [id])
  customer          Customer               @relation(fields: [customerId], references: [id])
  address           Address?
  generationReports GenerationReport[]
  contingencies     Contingency[]
  userPermissions   UserPlantPermission[]

  @@index([portfolioId])
  @@index([customerId])
  @@map("power_plants")
}

model User {
  id                  Int      @id @default(autoincrement())
  supabaseId          String   @unique @map("supabase_id")
  email               String   @unique
  name                String
  role                UserRole
  customerId          Int?     @map("customer_id")
  assignedPortfolioId Int?     @map("assigned_portfolio_id")
  active              Int      @default(1)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  customer                Customer?               @relation(fields: [customerId], references: [id])
  assignedPortfolio       Portfolio?              @relation("AssignedPortfolio", fields: [assignedPortfolioId], references: [id])
  plantPermissions        UserPlantPermission[]
  contingencies           Contingency[]           @relation("CreatedBy")
  contingencyComments     ContingencyComment[]    @relation("ContingencyComments")
  contingencyAttachments  ContingencyAttachment[] @relation("ContingencyAttachments")
  auditLogs               AuditLog[]

  @@index([customerId])
  @@index([supabaseId])
  @@map("users")
}

model UserPlantPermission {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  powerPlantId Int      @map("power_plant_id")
  active       Int      @default(1)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  powerPlant PowerPlant @relation(fields: [powerPlantId], references: [id], onDelete: Cascade)

  @@unique([userId, powerPlantId])
  @@map("user_plant_permissions")
}

model GenerationReport {
  id           Int      @id @default(autoincrement())
  powerPlantId Int      @map("power_plant_id")
  periodMonth  Int      @map("period_month")
  periodYear   Int      @map("period_year")
  fileUrl      String   @map("file_url")
  fileName     String   @map("file_name")
  kwhGenerated Float    @map("kwh_generated")
  co2Avoided   Float    @map("co2_avoided")
  active       Int      @default(1)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  powerPlant PowerPlant @relation(fields: [powerPlantId], references: [id])

  @@unique([powerPlantId, periodMonth, periodYear])
  @@index([powerPlantId])
  @@map("generation_reports")
}

model Invoice {
  id              Int      @id @default(autoincrement())
  customerId      Int      @map("customer_id")

  // Duemint fields
  duemintId       String   @unique @map("duemint_id")
  number          String?
  clientTaxId     String?  @map("client_tax_id")
  issueDate       DateTime? @map("issue_date")
  dueDate         DateTime? @map("due_date")
  statusCode      Int?     @map("status_code")
  statusName      String?  @map("status_name")
  currency        String?
  net             Float?
  taxes           Float?
  total           Float?
  paidAmount      Float?   @map("paid_amount")
  amountDue       Float?   @map("amount_due")
  amountCredit    Float?   @map("amount_credit")
  amountDebit     Float?   @map("amount_debit")
  isCeded         Boolean? @map("is_ceded")
  onJudicial      Boolean? @map("on_judicial")
  url             String?
  pdfUrl          String?  @map("pdf_url")
  xmlUrl          String?  @map("xml_url")

  // Duemint client fields (denormalized)
  duemintClientId   String? @map("duemint_client_id")
  duemintClientName String? @map("duemint_client_name")

  // Credit note (first element if exists)
  creditNoteId     String? @map("credit_note_id")
  creditNoteNumber String? @map("credit_note_number")

  portfolioId Int? @map("portfolio_id")

  active    Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer  Customer   @relation(fields: [customerId], references: [id])
  portfolio Portfolio? @relation(fields: [portfolioId], references: [id])

  @@index([customerId])
  @@index([portfolioId])
  @@index([clientTaxId])
  @@map("invoices")
}

model Contingency {
  id              Int               @id @default(autoincrement())
  powerPlantId    Int               @map("power_plant_id")
  type            ContingencyType
  description     String
  status          ContingencyStatus @default(OPEN)
  cost            Float?
  provider        String?
  workDescription String?           @map("work_description")
  createdById     Int               @map("created_by_id")
  closedAt        DateTime?         @map("closed_at")
  active          Int               @default(1)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  powerPlant  PowerPlant              @relation(fields: [powerPlantId], references: [id])
  createdBy   User                    @relation("CreatedBy", fields: [createdById], references: [id])
  comments    ContingencyComment[]
  attachment  ContingencyAttachment?

  @@index([powerPlantId])
  @@index([status])
  @@map("contingencies")
}

model ContingencyComment {
  id            Int         @id @default(autoincrement())
  contingencyId Int         @map("contingency_id")
  userId        Int         @map("user_id")
  body          String
  active        Int         @default(1)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  contingency Contingency @relation(fields: [contingencyId], references: [id])
  user        User        @relation("ContingencyComments", fields: [userId], references: [id])

  @@index([contingencyId])
  @@map("contingency_comments")
}

model ContingencyAttachment {
  id            Int      @id @default(autoincrement())
  contingencyId Int      @unique @map("contingency_id")
  userId        Int      @map("user_id")
  fileUrl       String   @map("file_url")
  fileName      String   @map("file_name")
  fileSize      Int?     @map("file_size")
  fileType      String?  @map("file_type")
  active        Int      @default(1)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  contingency Contingency @relation(fields: [contingencyId], references: [id])
  user        User        @relation("ContingencyAttachments", fields: [userId], references: [id])

  @@index([contingencyId])
  @@map("contingency_attachments")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  active     Int      @default(1)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}
